{
    "name": "opspulse-root",
    "version": "1.0.0",
    "scripts": {
        "dev:backend": "cd backend && npm run dev",
        "dev:frontend": "cd frontend && npm run dev",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
        "install:all": "npm install concurrently -g && (cd backend && npm install) && (cd frontend && npm install)"
    },
    "dependencies": {
        "concurrently": "^8.2.2"
    }
}